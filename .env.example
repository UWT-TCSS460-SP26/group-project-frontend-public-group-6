# ─────────────────────────────────────────────────────────────────────────────
# Auth.js v5 (NextAuth) — session signing for THIS app
# ─────────────────────────────────────────────────────────────────────────────
# AUTH_SECRET signs the JWT session cookie. Generate with:
#   openssl rand -base64 32
# AUTH_URL is the public origin of THIS app (the OAuth callback target).
AUTH_SECRET=
AUTH_URL=

# ─────────────────────────────────────────────────────────────────────────────
# auth-squared OIDC provider (deployed SP26 instance)
# Issuer has NO trailing slash. CLIENT_SECRET is rotated in the auth-sq admin
# portal: Tenants > tcss460-sp26 > Clients > tcss460-dev-shared > Rotate Secret.
# AUDIENCE must match the audience configured for backend-3 in auth-sq.
# ─────────────────────────────────────────────────────────────────────────────
AUTH_TCSS460_ISSUER=
AUTH_TCSS460_CLIENT_ID=
AUTH_TCSS460_CLIENT_SECRET=
AUTH_TCSS460_AUDIENCE=

# ─────────────────────────────────────────────────────────────────────────────
# backend-3 base URL — switchable between local and remote
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL (default — backend-3 running on your machine)
NEXT_PUBLIC_API_BASE_URL=
# REMOTE (deployed reference instance — uncomment and comment the local line above)
# NEXT_PUBLIC_API_BASE_URL=https://tcss-460-backend-3.onrender.com

# ─────────────────────────────────────────────────────────────────────────────
# Public values used by the /debug page for client-side JWKS verification
# (these are NOT secrets — they're just the issuer and audience exposed to the
# browser so the verify button can fetch and check the access token)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AUTH_ISSUER=
NEXT_PUBLIC_AUTH_AUDIENCE=
