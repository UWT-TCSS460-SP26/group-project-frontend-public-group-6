# ─────────────────────────────────────────────────────────────────────────────
# Auth.js v5 (NextAuth) — session signing for THIS app
# ─────────────────────────────────────────────────────────────────────────────
# AUTH_SECRET signs the JWT session cookie. Generate with:
#   openssl rand -base64 32
# AUTH_URL is the public origin of THIS app (the OAuth callback target).
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Auth² OIDC provider (deployed SP26 instance)
# Issuer has NO trailing slash. AUDIENCE must match Group 5's API (upstream partner).
# Client ID / secret: request from the instructor for group-6-consumer.
# ─────────────────────────────────────────────────────────────────────────────
AUTH_TCSS460_ISSUER=https://tcss-460-iam.onrender.com
AUTH_TCSS460_CLIENT_ID=
AUTH_TCSS460_CLIENT_SECRET=
AUTH_TCSS460_AUDIENCE=group-5-api

# ─────────────────────────────────────────────────────────────────────────────
# Upstream partner API — Group 5 (see README.md for Bug Tracker & OpenAPI URLs)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://tcss460-group-5-api.onrender.com

# ─────────────────────────────────────────────────────────────────────────────
# Public values for optional client-side JWT checks (not secrets)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AUTH_ISSUER=https://tcss-460-iam.onrender.com
NEXT_PUBLIC_AUTH_AUDIENCE=group-5-api
